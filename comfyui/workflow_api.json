{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sdxl_lightning_4step.safetensors"
    },
    "_meta": { "title": "SDXL Lightning 4-step" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "abstract generative art, dark background, luminous particles, chaotic trajectories, amber and cyan light, mathematical beauty, organic impossible geometry, deep shadows, high contrast"
    },
    "_meta": { "title": "Positive Prompt (overridden by bridge)" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "text, watermark, logo, signature, blurry, low quality, photograph, realistic face, human, person, grid, ui elements"
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1280,
      "height": 720,
      "batch_size": 1
    },
    "_meta": { "title": "Latent" }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 42,
      "steps": 4,
      "cfg": 2.0,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler (overridden by bridge)" }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "feedback_frame"
    },
    "_meta": { "title": "Save Frame" }
  }
}
