{
  "_comment": "Local Wan 2.2 VACE-Fun image-to-video using Kijai's WanVideoWrapper + GGUF models. API format for gen.py local Wan submissions. The bridge sets prompt, image, dims, seed, length, steps.",

  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2.2-VACE-Fun-A14B-HighNoise-Q4_K_M.gguf",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_fast",
      "load_device": "offload_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2.2-VACE-Fun-A14B-LowNoise-Q4_K_M.gguf",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_fast",
      "load_device": "offload_device",
      "attention_mode": "sdpa"
    }
  },
  "3": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "fp16",
      "load_device": "offload_device"
    }
  },
  "4": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2.1_VAE.safetensors",
      "precision": "bf16"
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "wan_ref.png"
    }
  },
  "20": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "t5": ["3", 0],
      "positive_prompt": "alabo_eye, ubani, dramatic cinematic motion",
      "negative_prompt": "blurry, low quality, distorted",
      "force_offload": true
    }
  },
  "30": {
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "vae": ["4", 0],
      "start_image": ["10", 0],
      "width": 768,
      "height": 1344,
      "num_frames": 81,
      "force_offload": true,
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0
    }
  },
  "40": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "model_low": ["2", 0],
      "image_embeds": ["30", 0],
      "text_embeds": ["20", 0],
      "steps": 20,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 42,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "denoise_strength": 1.0
    }
  },
  "50": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["4", 0],
      "samples": ["40", 0],
      "enable_vae_tiling": true,
      "tile_x": 272, "tile_y": 272,
      "tile_stride_x": 144, "tile_stride_y": 128
    }
  },
  "60": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["50", 0],
      "frame_rate": 16.0,
      "loop_count": 0,
      "filename_prefix": "wan_local",
      "format": "video/h264-mp4",
      "save_output": true
    }
  }
}
