{
  "_comment": "FLUX.1 Schnell — Bootstrap txt2img (first frame only). Split loading for VRAM efficiency.",

  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-schnell-fp8-e4m3fn.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "_meta": { "title": "FLUX.1 Schnell UNET (fp8)" }
  },

  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    },
    "_meta": { "title": "FLUX text encoders (CLIP-L + T5-XXL fp8)" }
  },

  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_meta": { "title": "FLUX VAE (ae)" }
  },

  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "abstract mathematical beauty, luminous particles tracing impossible trajectories through dark void, chaotic attractor geometry, deep shadows, high contrast, album cover artwork, warm amber and cool indigo, professional photography quality"
    },
    "_meta": { "title": "Positive prompt (overridden by bridge)" }
  },

  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": ""
    },
    "_meta": { "title": "Negative (empty for FLUX)" }
  },

  "40": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": { "title": "Empty latent (1024x1024 square)" }
  },

  "50": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "latent_image": ["40", 0],
      "seed": 42,
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler — 4 steps Schnell, cfg 1.0" }
  },

  "60": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["50", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "Decode to image" }
  },

  "70": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["60", 0],
      "filename_prefix": "feedback_frame"
    },
    "_meta": { "title": "Save frame" }
  }
}
