// ============================================
// RESONATOR ENSEMBLE — 6 Heterogeneous Voices
// Phase 1, Step 1.3
// ============================================
//
// 6 waveguide resonators, each with different character.
// Olly Wilson's heterogeneous sound ideal.
//
// 19 African tuning systems via Data lookup table.
//
// INPUTS:
//   in1-in6 = trigger for each resonator (impulse, 0 or 1)
//
// OUTPUTS:
//   out1 = mixed stereo left
//   out2 = mixed stereo right
//
// ============================================

// --- Global Parameters ---
Param root(110);
Param flex(0.5);              // Yoruba tuning (0=Pythagorean, 1=just)
Param tuning_system(0);       // 0-18, see table below
Param master_gain(0.7);

// --- Per-resonator degree selection ---
Param deg1(0);
Param deg2(1);
Param deg3(3);    // fifth
Param deg4(4);
Param deg5(0);    // root, octave below
Param deg6(2);

// --- Per-resonator octave offset ---
Param oct1(-1);
Param oct2(0);
Param oct3(0);
Param oct4(1);
Param oct5(-1);
Param oct6(1);

// --- Drive per resonator ---
Param drive(0.5);

// --- Decay control ---
// 0 = very percussive (hear every hit), 1 = infinite sustain (drone)
Param decay(0.3);

// --- Tuning lookup table ---
// 19 systems x 10 slots = 190 entries
// Slot layout: [0]=scale_size, [1..7]=ratios, [8..9]=unused
Data tuning_table(190);
History init_done(0);

// --- All History declarations ---
History r1_pt(0);
History r1_ec(0);
History r1_pd(0);
History r2_pt(0);
History r2_ec(0);
History r2_pd(0);
History r3_pt(0);
History r3_ec(0);
History r3_pd(0);
History r4_pt(0);
History r4_ec(0);
History r4_pd(0);
History r5_pt(0);
History r5_ec(0);
History r5_pd(0);
History r6_pt(0);
History r6_ec(0);
History r6_pd(0);

// Velocity latches (capture trigger amplitude)
History r1_vel(1);
History r2_vel(1);
History r3_vel(1);
History r4_vel(1);
History r5_vel(1);
History r6_vel(1);

// --- All Delay declarations ---
Delay r1_d(48000);
Delay r2_d(48000);
Delay r3_d(48000);
Delay r4_d(48000);
Delay r5_d(48000);
Delay r6_d(48000);


// =============================================
// TUNING TABLE INITIALIZATION (runs once)
// =============================================

if (init_done < 0.5) {

    // --- 0: Yoruba Pentatonic (Pythagorean base, flex-interpolated at runtime) ---
    poke(tuning_table, 5, 0, 0);
    poke(tuning_table, 1.0, 1, 0);
    poke(tuning_table, 1.125, 2, 0);
    poke(tuning_table, 1.265625, 3, 0);
    poke(tuning_table, 1.5, 4, 0);
    poke(tuning_table, 1.6875, 5, 0);

    // --- 1: Dundun 3-Tone (0, 200, 400 cents) ---
    poke(tuning_table, 3, 10, 0);
    poke(tuning_table, 1.0, 11, 0);
    poke(tuning_table, 1.12246, 12, 0);
    poke(tuning_table, 1.25992, 13, 0);

    // --- 2: Balafon Equi-Pentatonic (0, 220, 460, 690, 930 cents) ---
    poke(tuning_table, 5, 20, 0);
    poke(tuning_table, 1.0, 21, 0);
    poke(tuning_table, 1.13534, 22, 0);
    poke(tuning_table, 1.30486, 23, 0);
    poke(tuning_table, 1.49180, 24, 0);
    poke(tuning_table, 1.71002, 25, 0);

    // --- 3: Equi-Heptatonic 7-TET (0, 171, 343, 514, 686, 857, 1029 cents) ---
    poke(tuning_table, 7, 30, 0);
    poke(tuning_table, 1.0, 31, 0);
    poke(tuning_table, 1.10409, 32, 0);
    poke(tuning_table, 1.21901, 33, 0);
    poke(tuning_table, 1.34590, 34, 0);
    poke(tuning_table, 1.48599, 35, 0);
    poke(tuning_table, 1.64059, 36, 0);
    poke(tuning_table, 1.81145, 37, 0);

    // --- 4: BaAka/Pygmy 5-TET (0, 240, 480, 720, 960 cents) ---
    poke(tuning_table, 5, 40, 0);
    poke(tuning_table, 1.0, 41, 0);
    poke(tuning_table, 1.14870, 42, 0);
    poke(tuning_table, 1.31951, 43, 0);
    poke(tuning_table, 1.51572, 44, 0);
    poke(tuning_table, 1.74110, 45, 0);

    // --- 5: Shona Nyamaropa (0, 180, 380, 500, 700, 880, 1080 cents) ---
    poke(tuning_table, 7, 50, 0);
    poke(tuning_table, 1.0, 51, 0);
    poke(tuning_table, 1.10957, 52, 0);
    poke(tuning_table, 1.24574, 53, 0);
    poke(tuning_table, 1.33484, 54, 0);
    poke(tuning_table, 1.49831, 55, 0);
    poke(tuning_table, 1.65948, 56, 0);
    poke(tuning_table, 1.86121, 57, 0);

    // --- 6: Shona Gandanga (0, 100, 300, 500, 700, 800, 1000 cents) ---
    poke(tuning_table, 7, 60, 0);
    poke(tuning_table, 1.0, 61, 0);
    poke(tuning_table, 1.05946, 62, 0);
    poke(tuning_table, 1.18921, 63, 0);
    poke(tuning_table, 1.33484, 64, 0);
    poke(tuning_table, 1.49831, 65, 0);
    poke(tuning_table, 1.58740, 66, 0);
    poke(tuning_table, 1.78180, 67, 0);

    // --- 7: Kora Silaba (0, 200, 385, 500, 700, 900, 1085 cents) ---
    poke(tuning_table, 7, 70, 0);
    poke(tuning_table, 1.0, 71, 0);
    poke(tuning_table, 1.12246, 72, 0);
    poke(tuning_table, 1.24915, 73, 0);
    poke(tuning_table, 1.33484, 74, 0);
    poke(tuning_table, 1.49831, 75, 0);
    poke(tuning_table, 1.68179, 76, 0);
    poke(tuning_table, 1.86459, 77, 0);

    // --- 8: Kora Sauta (0, 185, 405, 605, 700, 885, 1105 cents) ---
    poke(tuning_table, 7, 80, 0);
    poke(tuning_table, 1.0, 81, 0);
    poke(tuning_table, 1.11278, 82, 0);
    poke(tuning_table, 1.26330, 83, 0);
    poke(tuning_table, 1.41747, 84, 0);
    poke(tuning_table, 1.49831, 85, 0);
    poke(tuning_table, 1.66230, 86, 0);
    poke(tuning_table, 1.88800, 87, 0);

    // --- 9: Ethiopian Tizita Major (0, 200, 400, 700, 900 cents) ---
    poke(tuning_table, 5, 90, 0);
    poke(tuning_table, 1.0, 91, 0);
    poke(tuning_table, 1.12246, 92, 0);
    poke(tuning_table, 1.25992, 93, 0);
    poke(tuning_table, 1.49831, 94, 0);
    poke(tuning_table, 1.68179, 95, 0);

    // --- 10: Ethiopian Tizita Minor (0, 200, 300, 700, 800 cents) ---
    poke(tuning_table, 5, 100, 0);
    poke(tuning_table, 1.0, 101, 0);
    poke(tuning_table, 1.12246, 102, 0);
    poke(tuning_table, 1.18921, 103, 0);
    poke(tuning_table, 1.49831, 104, 0);
    poke(tuning_table, 1.58740, 105, 0);

    // --- 11: Ethiopian Bati (0, 200, 500, 700, 900 cents) ---
    poke(tuning_table, 5, 110, 0);
    poke(tuning_table, 1.0, 111, 0);
    poke(tuning_table, 1.12246, 112, 0);
    poke(tuning_table, 1.33484, 113, 0);
    poke(tuning_table, 1.49831, 114, 0);
    poke(tuning_table, 1.68179, 115, 0);

    // --- 12: Ethiopian Ambassel (0, 200, 400, 700, 800 cents) ---
    poke(tuning_table, 5, 120, 0);
    poke(tuning_table, 1.0, 121, 0);
    poke(tuning_table, 1.12246, 122, 0);
    poke(tuning_table, 1.25992, 123, 0);
    poke(tuning_table, 1.49831, 124, 0);
    poke(tuning_table, 1.58740, 125, 0);

    // --- 13: Ethiopian Anchihoye (0, 100, 500, 600, 900 cents) ---
    poke(tuning_table, 5, 130, 0);
    poke(tuning_table, 1.0, 131, 0);
    poke(tuning_table, 1.05946, 132, 0);
    poke(tuning_table, 1.33484, 133, 0);
    poke(tuning_table, 1.41421, 134, 0);
    poke(tuning_table, 1.68179, 135, 0);

    // --- 14: Bugandan Amadinda (0, 240, 480, 720, 960 cents) ---
    poke(tuning_table, 5, 140, 0);
    poke(tuning_table, 1.0, 141, 0);
    poke(tuning_table, 1.14870, 142, 0);
    poke(tuning_table, 1.31951, 143, 0);
    poke(tuning_table, 1.51572, 144, 0);
    poke(tuning_table, 1.74110, 145, 0);

    // --- 15: Chopi Timbila (0, 175, 346, 519, 681, 854, 1025 cents) ---
    poke(tuning_table, 7, 150, 0);
    poke(tuning_table, 1.0, 151, 0);
    poke(tuning_table, 1.10653, 152, 0);
    poke(tuning_table, 1.22082, 153, 0);
    poke(tuning_table, 1.34890, 154, 0);
    poke(tuning_table, 1.48160, 155, 0);
    poke(tuning_table, 1.63720, 156, 0);
    poke(tuning_table, 1.80699, 157, 0);

    // --- 16: San Musical Bow (0, 200, 386, 498, 702, 884 cents) ---
    poke(tuning_table, 6, 160, 0);
    poke(tuning_table, 1.0, 161, 0);
    poke(tuning_table, 1.12246, 162, 0);
    poke(tuning_table, 1.24984, 163, 0);
    poke(tuning_table, 1.33322, 164, 0);
    poke(tuning_table, 1.50000, 165, 0);
    poke(tuning_table, 1.66212, 166, 0);

    // --- 17: Wagogo Ilimba — harmonics 4-9 (0, 386, 702, 969, 1200, 1404 cents) ---
    poke(tuning_table, 6, 170, 0);
    poke(tuning_table, 1.0, 171, 0);
    poke(tuning_table, 1.25, 172, 0);
    poke(tuning_table, 1.5, 173, 0);
    poke(tuning_table, 1.75, 174, 0);
    poke(tuning_table, 2.0, 175, 0);
    poke(tuning_table, 2.25, 176, 0);

    // --- 18: Igbo Pentatonic (0, 200, 386, 702, 884 cents) ---
    poke(tuning_table, 5, 180, 0);
    poke(tuning_table, 1.0, 181, 0);
    poke(tuning_table, 1.12246, 182, 0);
    poke(tuning_table, 1.24984, 183, 0);
    poke(tuning_table, 1.50000, 184, 0);
    poke(tuning_table, 1.66212, 185, 0);

    init_done = 1;
}


// =============================================
// TUNING LOOKUP SETUP
// =============================================

ts = clamp(floor(tuning_system), 0, 18);
ts_base = ts * 10;
ts_size = peek(tuning_table, ts_base, 0);
// Clamp ts_size to valid range (avoid division by zero)
ts_size = max(ts_size, 1);

// Yoruba just-intonation ratios (for flex interpolation, system 0 only)
j0 = 1.0; j1 = 1.111111; j2 = 1.25; j3 = 1.5; j4 = 1.666667;

// Decay scaling: each resonator has a base (percussive) and max (drone) damping
// decay=0 → short percussive hits, decay=1 → infinite sustain
dc = clamp(decay, 0, 1);
d1_damp = 0.5 + dc * 0.4995;     // r1: 0.50 — 0.9995 (sub bass)
d2_damp = 0.4 + dc * 0.598;      // r2: 0.40 — 0.998
d3_damp = 0.3 + dc * 0.696;      // r3: 0.30 — 0.996
d4_damp = 0.2 + dc * 0.77;       // r4: 0.20 — 0.97 (transient, click)
d5_damp = 0.4 + dc * 0.5998;     // r5: 0.40 — 0.9998
d6_damp = 0.3 + dc * 0.694;      // r6: 0.30 — 0.994


// =============================================
// RESONATOR 1: Sub Bass (iya ilu) — bright=0.2
// =============================================

deg1_w = mod(floor(deg1), ts_size);
oct1_x = floor(deg1 / ts_size);
r1_rat = peek(tuning_table, ts_base + 1 + deg1_w, 0);
// Flex interpolation (Yoruba only)
r1_jrat = (deg1_w<0.5)?j0:(deg1_w<1.5)?j1:(deg1_w<2.5)?j2:(deg1_w<3.5)?j3:j4;
r1_rat = (ts < 0.5) ? (r1_rat * (1.0-flex) + r1_jrat * flex) : r1_rat;
r1_freq = root * r1_rat * pow(2.0, oct1 + oct1_x);
r1_dlen = samplerate / max(r1_freq, 20);

r1_trig = (in1 > 0.05) * (r1_pt <= 0.05);
r1_vel = r1_trig ? in1 : r1_vel;
r1_pt = in1;
r1_ec = r1_trig ? r1_dlen : max(r1_ec - 1, 0);
r1_exc = (r1_ec > 0) ? noise() * drive * r1_vel : 0;

r1_del = r1_d.read(r1_dlen);
r1_avg = (r1_del + r1_pd) * 0.5;
r1_pd = r1_del;
r1_filt = r1_del * 0.2 + r1_avg * 0.8;    // brightness 0.2 = dark
r1_out = r1_filt * d1_damp;
r1_d.write(r1_exc + r1_out);


// =============================================
// RESONATOR 2: Body (omele) — bright=0.4
// =============================================

deg2_w = mod(floor(deg2), ts_size);
oct2_x = floor(deg2 / ts_size);
r2_rat = peek(tuning_table, ts_base + 1 + deg2_w, 0);
r2_jrat = (deg2_w<0.5)?j0:(deg2_w<1.5)?j1:(deg2_w<2.5)?j2:(deg2_w<3.5)?j3:j4;
r2_rat = (ts < 0.5) ? (r2_rat * (1.0-flex) + r2_jrat * flex) : r2_rat;
r2_freq = root * r2_rat * pow(2.0, oct2 + oct2_x);
r2_dlen = samplerate / max(r2_freq, 20);

r2_trig = (in2 > 0.05) * (r2_pt <= 0.05);
r2_vel = r2_trig ? in2 : r2_vel;
r2_pt = in2;
r2_ec = r2_trig ? r2_dlen : max(r2_ec - 1, 0);
r2_exc = (r2_ec > 0) ? noise() * drive * r2_vel : 0;

r2_del = r2_d.read(r2_dlen);
r2_avg = (r2_del + r2_pd) * 0.5;
r2_pd = r2_del;
r2_filt = r2_del * 0.4 + r2_avg * 0.6;    // brightness 0.4 = warm
r2_out = r2_filt * d2_damp;
r2_d.write(r2_exc + r2_out);


// =============================================
// RESONATOR 3: Metallic (ogene) — bright=0.85
// =============================================

deg3_w = mod(floor(deg3), ts_size);
oct3_x = floor(deg3 / ts_size);
r3_rat = peek(tuning_table, ts_base + 1 + deg3_w, 0);
r3_jrat = (deg3_w<0.5)?j0:(deg3_w<1.5)?j1:(deg3_w<2.5)?j2:(deg3_w<3.5)?j3:j4;
r3_rat = (ts < 0.5) ? (r3_rat * (1.0-flex) + r3_jrat * flex) : r3_rat;
r3_freq = root * r3_rat * pow(2.0, oct3 + oct3_x);
r3_dlen = samplerate / max(r3_freq, 20);

r3_trig = (in3 > 0.05) * (r3_pt <= 0.05);
r3_vel = r3_trig ? in3 : r3_vel;
r3_pt = in3;
r3_ec = r3_trig ? r3_dlen : max(r3_ec - 1, 0);
r3_exc = (r3_ec > 0) ? noise() * drive * r3_vel : 0;

r3_del = r3_d.read(r3_dlen);
r3_avg = (r3_del + r3_pd) * 0.5;
r3_pd = r3_del;
r3_filt = r3_del * 0.85 + r3_avg * 0.15;  // brightness 0.85 = bright
r3_out = r3_filt * d3_damp;
r3_d.write(r3_exc + r3_out);


// =============================================
// RESONATOR 4: Transient (gudugudu) — bright=0.9
// =============================================

deg4_w = mod(floor(deg4), ts_size);
oct4_x = floor(deg4 / ts_size);
r4_rat = peek(tuning_table, ts_base + 1 + deg4_w, 0);
r4_jrat = (deg4_w<0.5)?j0:(deg4_w<1.5)?j1:(deg4_w<2.5)?j2:(deg4_w<3.5)?j3:j4;
r4_rat = (ts < 0.5) ? (r4_rat * (1.0-flex) + r4_jrat * flex) : r4_rat;
r4_freq = root * r4_rat * pow(2.0, oct4 + oct4_x);
r4_dlen = samplerate / max(r4_freq, 20);

r4_trig = (in4 > 0.05) * (r4_pt <= 0.05);
r4_vel = r4_trig ? in4 : r4_vel;
r4_pt = in4;
r4_ec = r4_trig ? r4_dlen : max(r4_ec - 1, 0);
r4_exc = (r4_ec > 0) ? noise() * drive * 1.2 * r4_vel : 0;

r4_del = r4_d.read(r4_dlen);
r4_avg = (r4_del + r4_pd) * 0.5;
r4_pd = r4_del;
r4_filt = r4_del * 0.9 + r4_avg * 0.1;    // brightness 0.9 = very bright
r4_out = r4_filt * d4_damp;
r4_d.write(r4_exc + r4_out);


// =============================================
// RESONATOR 5: Drone — bright=0.3
// =============================================

deg5_w = mod(floor(deg5), ts_size);
oct5_x = floor(deg5 / ts_size);
r5_rat = peek(tuning_table, ts_base + 1 + deg5_w, 0);
r5_jrat = (deg5_w<0.5)?j0:(deg5_w<1.5)?j1:(deg5_w<2.5)?j2:(deg5_w<3.5)?j3:j4;
r5_rat = (ts < 0.5) ? (r5_rat * (1.0-flex) + r5_jrat * flex) : r5_rat;
r5_freq = root * r5_rat * pow(2.0, oct5 + oct5_x);
r5_dlen = samplerate / max(r5_freq, 20);

r5_trig = (in5 > 0.05) * (r5_pt <= 0.05);
r5_vel = r5_trig ? in5 : r5_vel;
r5_pt = in5;
r5_ec = r5_trig ? r5_dlen : max(r5_ec - 1, 0);
r5_exc = (r5_ec > 0) ? noise() * drive * 0.7 * r5_vel : 0;

r5_del = r5_d.read(r5_dlen);
r5_avg = (r5_del + r5_pd) * 0.5;
r5_pd = r5_del;
r5_filt = r5_del * 0.3 + r5_avg * 0.7;    // brightness 0.3 = dark
r5_out = r5_filt * d5_damp;
r5_d.write(r5_exc + r5_out);


// =============================================
// RESONATOR 6: Crystalline (shekere) — bright=0.95
// =============================================

deg6_w = mod(floor(deg6), ts_size);
oct6_x = floor(deg6 / ts_size);
r6_rat = peek(tuning_table, ts_base + 1 + deg6_w, 0);
r6_jrat = (deg6_w<0.5)?j0:(deg6_w<1.5)?j1:(deg6_w<2.5)?j2:(deg6_w<3.5)?j3:j4;
r6_rat = (ts < 0.5) ? (r6_rat * (1.0-flex) + r6_jrat * flex) : r6_rat;
r6_freq = root * r6_rat * pow(2.0, oct6 + oct6_x);
r6_dlen = samplerate / max(r6_freq, 20);

r6_trig = (in6 > 0.05) * (r6_pt <= 0.05);
r6_vel = r6_trig ? in6 : r6_vel;
r6_pt = in6;
r6_ec = r6_trig ? r6_dlen : max(r6_ec - 1, 0);
r6_exc = (r6_ec > 0) ? noise() * drive * r6_vel : 0;

r6_del = r6_d.read(r6_dlen);
r6_avg = (r6_del + r6_pd) * 0.5;
r6_pd = r6_del;
r6_filt = r6_del * 0.95 + r6_avg * 0.05;  // brightness 0.95 = crystalline
r6_out = r6_filt * d6_damp;
r6_d.write(r6_exc + r6_out);


// =============================================
// STEREO MIX
// =============================================

left  = r1_out * 0.6 + r2_out * 0.35 + r3_out * 0.65
      + r4_out * 0.4 + r5_out * 0.55 + r6_out * 0.45;

right = r1_out * 0.4 + r2_out * 0.65 + r3_out * 0.35
      + r4_out * 0.6 + r5_out * 0.45 + r6_out * 0.55;

out1 = left * master_gain;
out2 = right * master_gain;
