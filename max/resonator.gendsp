		"boxes" : [ 			{
				"box" : 				{
					"id" : "obj-in1",
					"maxclass" : "newobj",
					"text" : "in 1",
					"numinlets" : 0,
					"numoutlets" : 1,
					"outlettype" : [ "" ],
					"patching_rect" : [ 50.0, 15.0, 30.0, 22.0 ]
