			},
			{
				"box" : 				{
					"id" : "obj-codebox",
					"maxclass" : "codebox",
					"numinlets" : 1,
					"numoutlets" : 1,
					"outlettype" : [ "" ],
					"patching_rect" : [ 50.0, 55.0, 600.0, 380.0 ],
					"code" : "// WAVEGUIDE RESONATOR — Karplus-Strong\n\nParam freq(110);\nParam damping(0.997);\nParam brightness(0.5);\nParam drive(0.5);\n\ndelay_len = samplerate / max(freq, 20);\n\n// Trigger detection (rising edge)\nHistory prev_trig(0);\ntrigger = (in1 > 0.5) * (prev_trig <= 0.5);\nprev_trig = in1;\n\n// Noise burst excitation — fills one delay cycle\nHistory exc_count(0);\nexc_count = trigger ? delay_len : max(exc_count - 1, 0);\nexcitation = (exc_count > 0) ? noise() * drive : 0;\n\n// Delay line\nDelay d(48000);\ndelayed = d.read(delay_len);\n\n// Karplus-Strong averaging filter\nHistory prev_del(0);\navg = (delayed + prev_del) * 0.5;\nprev_del = delayed;\nfiltered = delayed * brightness + avg * (1.0 - brightness);\n\n// Damping\noutput = filtered * damping;\n\n// Write excitation + feedback\nd.write(excitation + output);\n\nout1 = output;"
				}
			},
			{
				"box" : 				{
					"id" : "obj-out1",
					"maxclass" : "newobj",
					"text" : "out 1",
					"numinlets" : 1,
